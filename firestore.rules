rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------
    // 共通関数
    // ------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth != null && request.auth.token.get('admin', false) == true;
    }

    // ------------------------------------------
    // 1. Users コレクション
    // ------------------------------------------
    match /users/{userId} {
      // 本人または管理者のみ読み取り可能
      allow read: if isOwner(userId) || isAdmin();

      // プロフィールの作成（新規登録時）
      allow create: if isOwner(userId) || isAdmin();

      // プロフィールの更新:
      //   管理者 → 全フィールド可
      //   本人   → icon / hasAgreedToTerms / lastLoginAt のみ（スコア・XP 等はサーバー経由のみ）
      allow update: if isAdmin()
        || (isOwner(userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['icon', 'hasAgreedToTerms', 'lastLoginAt']));
      
      // サブコレクション（attempts, wrong_answers）
      match /attempts/{attemptId} {
        allow read: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
        allow create, update: if false; // Cloud Functions からのみ実行
      }
      
      match /wrong_answers/{unitId} {
        allow read: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
        allow create, update: if false; // Cloud Functions からのみ実行
      }
    }

    // ── CollectionGroup query for attempts（管理者分析用） ──
    match /{path=**}/attempts/{docId} {
      allow read: if isAdmin();
    }

    // ── CollectionGroup query for stats（管理者分析用） ──
    match /{path=**}/stats/{docId} {
      allow read: if isAdmin();
    }

    // ── CollectionGroup query for wrong_answers（管理者リセット用） ──
    match /{path=**}/wrong_answers/{docId} {
      allow read, delete: if isAdmin();
    }

    // ------------------------------------------
    // リーダーボード（集計済みランキング）
    // - 認証済みユーザーは閲覧可能
    // - 書き込みは Cloud Functions (Admin SDK) からのみ
    // ------------------------------------------
    match /leaderboards/{docId} {
      allow read: if isAuthenticated();
      allow delete: if isAdmin();
      allow create, update: if isAdmin(); // Cloud Functions だけでなく管理者も更新可能に
    }

    // ------------------------------------------
    // グローバル統計（管理画面用）
    // - 管理者のみ読み取り可能
    // - 書き込みは Cloud Functions (Admin SDK) からのみ
    // ------------------------------------------
    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ------------------------------------------
    // 2. Scores コレクション (ランキング用)
    // ------------------------------------------
    match /scores/{scoreId} {
      // ランキング表示のため、認証済みユーザーなら誰でも読み取り可能
      allow read: if isAuthenticated();
      
      // 管理者のみ管理画面からの削除や更新（不正無視フラグ設定など）が可能
      allow write: if isAdmin();
    }

    // ------------------------------------------
    // 3. Units コレクション
    // ------------------------------------------
    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /questions/{qId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      match /stats/{docId} {
        allow read: if isAuthenticated();
        // admin 以外は Cloud Functions 経由で間接的に更新
        allow write: if isAdmin();
      }
    }

    // ------------------------------------------
    // 4. 管理用 (Suspicious Activities 他)
    // ------------------------------------------
    match /suspicious_activities/{id} {
      // 管理者のみ読み取り、アーカイブ/削除が可能。作成は Cloud Functions (Admin SDK)
      allow read, delete, update: if isAdmin();
      allow create: if false;
    }

    // ------------------------------------------
    // 5. 分析キャッシュ (管理者のみ)
    // ------------------------------------------
    match /analytics_cache/{docId} {
      allow read, write: if isAdmin();
    }

    // ------------------------------------------
    // 6. 更新履歴 (管理者のみ)
    // ------------------------------------------
    match /changelog/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ------------------------------------------
    // 7. システム設定 (メンテナンスモードなど)
    // ------------------------------------------
    match /config/{configId} {
      // メンテナンスモードなどのシステム設定
      // 全ユーザーが読み取り可能（非ログインユーザーもメンテナンス画面を見るため）
      allow read: if configId == 'maintenance' || configId == 'maintenance_kanji';
      // 管理者のみ書き込み可能
      allow write: if isAdmin();
    }
  }
}