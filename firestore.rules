rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: 管理者判定（Custom Claims ベース） ──
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── /users/{userId} ──
    // Read: 本人 + 管理者のみ（他の生徒の個人情報を保護）
    // Write: 本人のみ
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);

      // サブコレクション（attempts, wrong_answers 等）
      match /{document=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }

    // ── CollectionGroup query for attempts（管理者分析用） ──
    match /{path=**}/attempts/{docId} {
      allow read: if isAdmin();
    }

    // ── /units/{unitId} ──
    // Read: 認証済みユーザー全員（ドリル実施に必要）
    // Write: 管理者のみ
    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      // stats サブコレクション
      // Read: 認証済みユーザー全員
      // Write: 管理者のみ（Cloud Functions 経由で更新）
      match /stats/{statId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ── /scores/{scoreId} ──
    // Read: 認証済みユーザー全員（ランキング表示に必要）
    // Create: 本人のみ（uid チェック）
    // Update: 本人のみ（uid チェック）
    // Delete: 管理者のみ
    match /scores/{scoreId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.uid && request.auth.uid == request.resource.data.uid;
      allow delete: if isAdmin();
    }
  }
}