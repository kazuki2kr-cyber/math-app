rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }
    match /units/{unitId} {
      // 誰でも読み取り可能に（または auth != null に）
      allow read: if true;
      // 管理者のみ書き込み可能とするのが望ましいが、テストのためすべて許可または限定
      allow write: if request.auth != null && (request.auth.token.email == 'kazuki2kr@gmail.com' || request.auth.token.email == 'ichikawa.kazuki@shibaurafzk.com');
    }
    match /scores/{scoreId} {
      // 自分のスコアは読み書き可能
      allow read: if true; // ランキング用に全ユーザーが読み取れる必要がある
      // 新規作成時は resource がまだ無いため request.resource で判定。既存更新時は request.auth.uid == request.resource.data.uid
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null && request.auth.uid == resource.data.uid && request.auth.uid == request.resource.data.uid;
    }
  }
}