rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------
    // 共通関数
    // ------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ------------------------------------------
    // 1. Users コレクション
    // ------------------------------------------
    match /users/{userId} {
      // 本人または管理者のみ読み取り可能
      allow read: if isOwner(userId) || isAdmin();
      
      // プロフィールの作成（新規登録時）
      allow create: if (isOwner(userId) 
        && request.resource.data.xp == 0 
        && request.resource.data.isAdmin == false) || isAdmin();
      
      // プロフィールの更新（アイコン、ログイン日時、規約同意のみ許可。管理者は全フィールド可）
      allow update: if (isOwner(userId) 
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastLoginAt', 'hasAgreedToTerms', 'icon', 'displayName', 'photoURL']))
        || isAdmin();
      
      // サブコレクション（attempts, wrong_answers）
      match /attempts/{attemptId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Cloud Functions からのみ実行
      }
      
      match /wrong_answers/{unitId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Cloud Functions からのみ実行
      }
    }

    // ── CollectionGroup query for attempts（管理者分析用） ──
    match /{path=**}/attempts/{docId} {
      allow read: if isAdmin();
    }

    // ------------------------------------------
    // 2. Scores コレクション (ランキング用)
    // ------------------------------------------
    match /scores/{scoreId} {
      // ランキング表示のため、認証済みユーザーなら誰でも読み取り可能
      allow read: if isAuthenticated();
      
      // 書き込みは Cloud Functions (Admin SDK) のみ
      allow write: if false;
    }

    // ------------------------------------------
    // 3. Units コレクション
    // ------------------------------------------
    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /stats/{docId} {
        allow read: if isAuthenticated();
        // admin 以外は Cloud Functions 経由で間接的に更新
        allow write: if isAdmin();
      }
    }

    // ------------------------------------------
    // 4. 管理用 (Suspicious Activities 他)
    // ------------------------------------------
    match /suspicious_activities/{id} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions (Admin SDK) のみ
    }
  }
}